[sub_resource type="Shader" id="Shader_ywbvk"]
code = "shader_type canvas_item;
uniform sampler2D palette;

uniform vec3 exclusion_list[16];
uniform int exclusion_list_size : hint_range(0,16) = 0;

void fragment() {
    vec4 tex_color = texture(TEXTURE, UV);
	
	bool found = false;
	for(int i = 0; i < exclusion_list_size; i++)
	{
		if(distance(tex_color.rgb, exclusion_list[i]) < 0.01)
		{
			found = true;
		} 
	}
	
	if(found)
	{
		COLOR = tex_color;
	}
	else
	{
		// Replace
		vec4 new_color = texture(palette, vec2(tex_color.r, 0));
    	COLOR = vec4(new_color.rgb, tex_color.a);	
	}
	
    
}
"

