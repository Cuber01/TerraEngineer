~ start
Terraforming Terminal:
- Forest
	set GlobalDialoguesState.PuzzleTerraformingRoom_Biome = 0
- Fungus
	set GlobalDialoguesState.PuzzleTerraformingRoom_Biome = 1
- Tundra
	set GlobalDialoguesState.PuzzleTerraformingRoom_Biome = 3
- Desert
	set GlobalDialoguesState.PuzzleTerraformingRoom_Biome = 4
=> END